/* pages/register/register.wxss */
.container {
  padding: 60rpx 40rpx;
  background: linear-gradient(135deg, #27ae60 0%, #2ecc71 100%);
  min-height: 100vh;
}

.register-header {
  text-align: center;
  margin-bottom: 80rpx;
}

.page-title {
  color: white;
  font-size: 48rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
}

.subtitle {
  color: rgba(255,255,255,0.8);
  font-size: 28rpx;
  display: block;
}

.register-form {
  background: white;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
}

.form-group {
  position: relative;
  margin-bottom: 40rpx;
}

.form-label {
  color: #2c3e50;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
  display: block;
}

.form-input {
  width: 100%;
  padding: 25rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #27ae60;
  outline: none;
}

.password-toggle {
  position: absolute;
  right: 25rpx;
  top: 60rpx;
  color: #27ae60;
  font-size: 24rpx;
}

.register-btn {
  margin-top: 40rpx;
  padding: 25rpx;
  font-size: 32rpx;
  font-weight: bold;
  background-color: #27ae60;
}

.form-footer {
  text-align: center;
  margin-top: 40rpx;
}

.link-text {
  color: #27ae60;
  font-size: 26rpx;
}
