<!--pages/register/register.wxml-->
<view class="container">
  <view class="register-header">
    <text class="page-title">{{typeText}}注册</text>
    <text class="subtitle">创建您的账号</text>
  </view>
  
  <view class="register-form">
    <view class="form-group">
      <text class="form-label">用户名</text>
      <input class="form-input" 
             placeholder="请输入用户名" 
             value="{{username}}" 
             bindinput="onUsernameInput"/>
    </view>
    
    <view class="form-group">
      <text class="form-label">密码</text>
      <input class="form-input" 
             placeholder="请输入密码" 
             password="{{!showPassword}}" 
             value="{{password}}" 
             bindinput="onPasswordInput"/>
      <text class="password-toggle" bindtap="togglePassword">
        {{showPassword ? '隐藏' : '显示'}}
      </text>
    </view>
    
    <view class="form-group">
      <text class="form-label">确认密码</text>
      <input class="form-input" 
             placeholder="请再次输入密码" 
             password="{{!showConfirmPassword}}" 
             value="{{confirmPassword}}" 
             bindinput="onConfirmPasswordInput"/>
      <text class="password-toggle" bindtap="toggleConfirmPassword">
        {{showConfirmPassword ? '隐藏' : '显示'}}
      </text>
    </view>
    
    <button class="btn-primary register-btn" bindtap="handleRegister">注册</button>
    
    <view class="form-footer">
      <text class="link-text" bindtap="goToLogin">已有账号？立即登录</text>
    </view>
  </view>
</view>
