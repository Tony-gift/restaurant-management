/* pages/employee/home/home.wxss */
.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.user-info {
  background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
  padding: 60rpx 40rpx 40rpx;
  display: flex;
  align-items: center;
  color: white;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  margin-right: 30rpx;
}

.user-details {
  flex: 1;
}

.username {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.user-type {
  font-size: 24rpx;
  opacity: 0.8;
}

.logout-btn {
  font-size: 28rpx;
  padding: 15rpx 30rpx;
  border: 2rpx solid white;
  border-radius: 20rpx;
}

.function-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 30rpx;
  padding: 40rpx;
}

.function-item {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
  transition: all 0.3s ease;
}

.function-item:active {
  transform: scale(0.95);
}

.function-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 20rpx;
}

.function-text {
  font-size: 28rpx;
  color: #2c3e50;
  font-weight: bold;
}

.notice-section {
  margin: 0 40rpx 40rpx;
}

.section-header {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2c3e50;
}

.notice-list {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.notice-item {
  padding: 30rpx;
  border-bottom: 1rpx solid #e0e0e0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.notice-item:last-child {
  border-bottom: none;
}

.notice-title {
  font-size: 28rpx;
  color: #2c3e50;
  flex: 1;
}

.notice-time {
  font-size: 24rpx;
  color: #7f8c8d;
}
