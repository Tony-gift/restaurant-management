/* pages/employee/attendance/attendance.wxss */
.container {
  padding: 40rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.attendance-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.page-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #2c3e50;
  margin-bottom: 20rpx;
}

.current-time {
  font-size: 28rpx;
  color: #7f8c8d;
}

.punch-section {
  margin-bottom: 60rpx;
}

.punch-card {
  background: white;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
}

.punch-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2c3e50;
  display: block;
  margin-bottom: 40rpx;
}

.punch-status {
  margin-bottom: 40rpx;
}

.status-text {
  display: block;
  font-size: 28rpx;
  margin-bottom: 15rpx;
}

.punch-btn {
  background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
  color: white;
  border-radius: 50rpx;
  padding: 30rpx 80rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

.punch-btn.disabled {
  background: #bdc3c7;
}

.stats-section, .history-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2c3e50;
  display: block;
  margin-bottom: 30rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.stat-item {
  background: white;
  border-radius: 16rpx;
  padding: 40rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.stat-number {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #3498db;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #7f8c8d;
}

.history-list {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.history-item {
  padding: 30rpx;
  border-bottom: 1rpx solid #e0e0e0;
  display: flex;
  align-items: center;
}

.history-item:last-child {
  border-bottom: none;
}

.history-date {
  width: 140rpx;
  text-align: center;
}

.date-text {
  display: block;
  font-size: 24rpx;
  color: #2c3e50;
  font-weight: bold;
}

.day-text {
  font-size: 20rpx;
  color: #7f8c8d;
}

.history-times {
  flex: 1;
  margin-left: 30rpx;
}

.time-text {
  display: block;
  font-size: 24rpx;
  color: #2c3e50;
  margin-bottom: 8rpx;
}

.history-status {
  width: 120rpx;
  text-align: center;
}

.status-tag {
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  color: white;
}

.status-tag.normal {
  background-color: #27ae60;
}

.status-tag.late {
  background-color: #f39c12;
}

.status-tag.absent {
  background-color: #e74c3c;
}
