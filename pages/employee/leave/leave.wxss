/* pages/employee/leave/leave.wxss */
.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.tabs {
  background: white;
  display: flex;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #7f8c8d;
  border-bottom: 4rpx solid transparent;
}

.tab-item.active {
  color: #3498db;
  border-bottom-color: #3498db;
  font-weight: bold;
}

.tab-content {
  padding: 40rpx;
}

.form-section {
  background: white;
  border-radius: 16rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.form-group {
  margin-bottom: 40rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #2c3e50;
  margin-bottom: 20rpx;
}

.picker-input {
  padding: 25rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #2c3e50;
  background: white;
}

.days-display {
  padding: 25rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #3498db;
  font-weight: bold;
  background: #f8f9fa;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 25rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #7f8c8d;
  margin-top: 10rpx;
}

.submit-btn {
  margin-top: 40rpx;
  padding: 25rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.records-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-item {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.record-type {
  font-size: 28rpx;
  font-weight: bold;
  color: #2c3e50;
}

.record-status {
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: white;
}

.record-status.pending {
  background-color: #f39c12;
}

.record-status.approved {
  background-color: #27ae60;
}

.record-status.rejected {
  background-color: #e74c3c;
}

.record-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.record-date {
  font-size: 26rpx;
  color: #2c3e50;
}

.record-days {
  font-size: 26rpx;
  color: #3498db;
  font-weight: bold;
}

.record-reason {
  margin-bottom: 20rpx;
}

.reason-label {
  font-size: 24rpx;
  color: #7f8c8d;
}

.reason-text {
  font-size: 26rpx;
  color: #2c3e50;
  margin-left: 10rpx;
}

.record-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.apply-time {
  font-size: 24rpx;
  color: #7f8c8d;
}

.record-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  padding: 10rpx 25rpx;
  border-radius: 15rpx;
  font-size: 24rpx;
  color: white;
}

.action-btn.cancel {
  background-color: #e74c3c;
}
