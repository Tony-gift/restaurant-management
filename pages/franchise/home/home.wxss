/* pages/franchise/home/home.wxss */
.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.user-info {
  background: linear-gradient(135deg, #27ae60 0%, #2ecc71 100%);
  padding: 60rpx 40rpx 40rpx;
  display: flex;
  align-items: center;
  color: white;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  margin-right: 30rpx;
}

.user-details {
  flex: 1;
}

.username {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.user-type {
  font-size: 24rpx;
  opacity: 0.8;
}

.logout-btn {
  font-size: 28rpx;
  padding: 15rpx 30rpx;
  border: 2rpx solid white;
  border-radius: 20rpx;
}

.status-card {
  margin: 40rpx;
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
}

.status-header {
  margin-bottom: 30rpx;
}

.status-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2c3e50;
}

.status-content {
  text-align: center;
}

.status-indicator {
  padding: 20rpx 40rpx;
  border-radius: 25rpx;
  margin-bottom: 20rpx;
  display: inline-block;
}

.status-indicator.pending {
  background-color: #fff3cd;
  border: 1rpx solid #ffeaa7;
}

.status-indicator.approved {
  background-color: #d4edda;
  border: 1rpx solid #c3e6cb;
}

.status-indicator.rejected {
  background-color: #f8d7da;
  border: 1rpx solid #f5c6cb;
}

.status-text {
  font-size: 28rpx;
  font-weight: bold;
}

.status-indicator.pending .status-text {
  color: #856404;
}

.status-indicator.approved .status-text {
  color: #155724;
}

.status-indicator.rejected .status-text {
  color: #721c24;
}

.status-desc {
  font-size: 26rpx;
  color: #7f8c8d;
  display: block;
}

.function-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 30rpx;
  padding: 0 40rpx 40rpx;
}

.function-item {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
  transition: all 0.3s ease;
}

.function-item:active {
  transform: scale(0.95);
}

.function-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 20rpx;
}

.function-text {
  font-size: 28rpx;
  color: #2c3e50;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.function-desc {
  font-size: 24rpx;
  color: #7f8c8d;
}

.info-section {
  margin: 0 40rpx 40rpx;
}

.section-header {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2c3e50;
}

.info-list {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.info-item {
  padding: 30rpx;
  border-bottom: 1rpx solid #e0e0e0;
  display: flex;
  align-items: flex-start;
}

.info-item:last-child {
  border-bottom: none;
}

.info-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  margin-top: 5rpx;
}

.info-content {
  flex: 1;
}

.info-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #2c3e50;
  margin-bottom: 10rpx;
}

.info-desc {
  font-size: 26rpx;
  color: #7f8c8d;
  line-height: 1.5;
}
