/* pages/franchise/application/application.wxss */
.container {
  padding: 40rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.form-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #2c3e50;
  display: block;
  margin-bottom: 20rpx;
}

.form-desc {
  font-size: 26rpx;
  color: #7f8c8d;
  line-height: 1.5;
}

.form-section {
  background: white;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #2c3e50;
  display: block;
  margin-bottom: 30rpx;
  padding-bottom: 15rpx;
  border-bottom: 2rpx solid #e0e0e0;
}

.form-group {
  margin-bottom: 40rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #2c3e50;
  margin-bottom: 20rpx;
}

.form-input {
  width: 100%;
  padding: 25rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: white;
}

.form-input:focus {
  border-color: #27ae60;
  outline: none;
}

.picker-input {
  width: 100%;
  padding: 25rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #2c3e50;
  background: white;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 150rpx;
  padding: 25rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: white;
}

.form-textarea:focus {
  border-color: #27ae60;
  outline: none;
}

.form-footer {
  background: white;
  border-radius: 16rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.agreement-item {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.agreement-text {
  font-size: 26rpx;
  color: #2c3e50;
  margin-left: 20rpx;
}

.agreement-link {
  font-size: 26rpx;
  color: #27ae60;
  margin-left: 10rpx;
  text-decoration: underline;
}

.submit-btn {
  width: 100%;
  padding: 25rpx;
  font-size: 32rpx;
  font-weight: bold;
  background-color: #27ae60;
}

.submit-btn[disabled] {
  background-color: #bdc3c7;
  color: #7f8c8d;
}
