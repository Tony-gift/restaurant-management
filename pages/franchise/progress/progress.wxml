<!--pages/franchise/progress/progress.wxml-->
<view class="container">
  <view class="progress-header">
    <text class="page-title">申请进度</text>
    <text class="application-id">申请编号：{{applicationInfo.id || 'N/A'}}</text>
  </view>
  
  <view class="current-status" wx:if="{{applicationInfo.id}}">
    <view class="status-card">
      <view class="status-icon {{applicationInfo.status}}">
        <text class="icon-text">{{getStatusIcon(applicationInfo.status)}}</text>
      </view>
      <view class="status-info">
        <text class="status-title">{{getStatusText(applicationInfo.status)}}</text>
        <text class="status-desc">{{getStatusDesc(applicationInfo.status)}}</text>
      </view>
    </view>
  </view>
  
  <view class="no-application" wx:if="{{!applicationInfo.id}}">
    <image class="empty-icon" src="/images/empty.png" mode="aspectFit"></image>
    <text class="empty-text">您还没有提交加盟申请</text>
    <button class="btn-primary apply-btn" bindtap="goToApplication">立即申请</button>
  </view>
  
  <view class="progress-timeline" wx:if="{{applicationInfo.id}}">
    <text class="section-title">审核流程</text>
    
    <view class="timeline">
      <view class="timeline-item {{item.completed ? 'completed' : (item.current ? 'current' : 'pending')}}" 
            wx:for="{{progressSteps}}" wx:key="step">
        <view class="timeline-dot">
          <text class="dot-text" wx:if="{{item.completed}}">✓</text>
          <text class="dot-number" wx:elif="{{item.current}}">{{index + 1}}</text>
          <view class="dot-circle" wx:else></view>
        </view>
        <view class="timeline-content">
          <text class="step-title">{{item.title}}</text>
          <text class="step-desc">{{item.description}}</text>
          <text class="step-time" wx:if="{{item.completedTime}}">{{item.completedTime}}</text>
        </view>
      </view>
    </view>
  </view>
  
  <view class="application-detail" wx:if="{{applicationInfo.id}}">
    <text class="section-title">申请信息</text>
    
    <view class="detail-card">
      <view class="detail-item">
        <text class="detail-label">申请人</text>
        <text class="detail-value">{{applicationInfo.applicantName}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">公司名称</text>
        <text class="detail-value">{{applicationInfo.companyName}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">联系电话</text>
        <text class="detail-value">{{applicationInfo.phone}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">店铺位置</text>
        <text class="detail-value">{{applicationInfo.storeLocation}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">提交时间</text>
        <text class="detail-value">{{applicationInfo.submitTime}}</text>
      </view>
    </view>
    
    <view class="action-buttons" wx:if="{{applicationInfo.status === 'pending'}}">
      <button class="btn-secondary cancel-btn" bindtap="cancelApplication">撤销申请</button>
      <button class="btn-primary contact-btn" bindtap="contactService">联系客服</button>
    </view>
  </view>
</view>
