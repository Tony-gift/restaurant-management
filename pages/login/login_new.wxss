/* pages/login/login.wxss */
.container {
  padding: 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
}

/* 头部区域 */
.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.logo-container {
  margin-bottom: 30rpx;
}

.logo-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 20rpx;
}

.page-title {
  color: white;
  font-size: 48rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 15rpx;
}

.subtitle {
  color: rgba(255,255,255,0.9);
  font-size: 28rpx;
  display: block;
}

/* 身份选择卡片 */
.user-type-cards {
  display: flex;
  flex-direction: column;
  gap: 25rpx;
  margin-bottom: 40rpx;
}

.type-card {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
  transition: all 0.3s ease;
}

.type-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.25);
}

.card-icon {
  width: 60rpx;
  height: 60rpx;
  margin-right: 30rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2c3e50;
  margin-bottom: 8rpx;
  flex: 1;
}

.card-desc {
  font-size: 24rpx;
  color: #7f8c8d;
  position: absolute;
  right: 30rpx;
}

/* 登录表单区域 */
.login-form {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
}

.selected-type {
  background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
  padding: 30rpx;
  display: flex;
  align-items: center;
  color: white;
  position: relative;
}

.selected-icon {
  width: 50rpx;
  height: 50rpx;
  margin-right: 20rpx;
}

.selected-text {
  font-size: 32rpx;
  font-weight: bold;
  flex: 1;
}

.change-type {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  padding: 10rpx 20rpx;
  border: 1rpx solid rgba(255,255,255,0.3);
  border-radius: 20rpx;
}

.form-container {
  padding: 40rpx;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  color: #2c3e50;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
  display: block;
}

.form-input {
  width: 100%;
  padding: 25rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #3498db;
  outline: none;
}

.password-container {
  position: relative;
}

.password-toggle {
  position: absolute;
  right: 25rpx;
  top: 25rpx;
  color: #3498db;
  font-size: 24rpx;
}

.login-btn {
  width: 100%;
  margin-top: 30rpx;
  padding: 25rpx;
  font-size: 32rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
  color: white;
  border: none;
  border-radius: 12rpx;
}

.login-btn:active {
  opacity: 0.8;
}

.form-footer {
  text-align: center;
  margin-top: 30rpx;
}

.link-text {
  color: #3498db;
  font-size: 26rpx;
}

/* 通用按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
  color: white;
  border: none;
  border-radius: 12rpx;
}

.btn-primary:active {
  opacity: 0.8;
}
