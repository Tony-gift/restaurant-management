/* pages/login/form/form.wxss */
.container {
  padding: 60rpx 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
}

.login-header {
  text-align: center;
  margin-bottom: 80rpx;
}

.page-title {
  color: white;
  font-size: 48rpx;
  font-weight: bold;
}

/* Logo图片容器样式 */
.logo-container {
  text-align: center;
  margin-bottom: 60rpx;
}

.logo-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 20rpx;
}

.login-form {
  background: white;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
}

.form-group {
  position: relative;
  margin-bottom: 40rpx;
}

.form-label {
  color: #2c3e50;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
  display: block;
}

.form-input {
  width: 100%;
  padding: 25rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #3498db;
  outline: none;
}

.password-toggle {
  position: absolute;
  right: 25rpx;
  top: 60rpx;
  color: #3498db;
  font-size: 24rpx;
}

.login-btn {
  margin-top: 40rpx;
  padding: 25rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.form-footer {
  text-align: center;
  margin-top: 40rpx;
}

.link-text {
  color: #3498db;
  font-size: 26rpx;
}
