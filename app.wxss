/**app.wxss**/
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 0;
  box-sizing: border-box;
} 

/* 通用样式 */
.btn-primary {
  background-color: #3498db;
  color: white;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  margin: 20rpx 0;
  width: 100%;
  text-align: center;
}

.btn-secondary {
  background-color: #95a5a6;
  color: white;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  margin: 20rpx 0;
  width: 100%;
  text-align: center;
}

.btn-success {
  background-color: #27ae60;
  color: white;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  margin: 20rpx 0;
  width: 100%;
  text-align: center;
}

.form-group {
  margin: 30rpx 0;
  width: 100%;
}

.form-label {
  display: block;
  margin-bottom: 10rpx;
  font-weight: bold;
  color: #2c3e50;
}

.form-input {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #bdc3c7;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #2c3e50;
  text-align: center;
  margin: 40rpx 0;
}
